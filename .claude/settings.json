{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh *)",
      "Bash(*/gradlew *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(echo *)",
      "Bash(docker *)",
      "Bash(jq *)",
      "Bash(java *)",
      "Bash(javac *)",
      "Bash(colima *)",
      "Bash(xargs *)",
      "Bash(docker-compose *)",
      "Bash(yarn build)",
      "Bash(open *github*)",
      "Bash(curl:*)",
      "Bash(sort:*)",
      "Bash(done)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/credentials.json)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(wget:*)",
      "Bash(ssh:*)",
      "Bash(rm -rf:*)"
    ]
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/redirect-to-native-tools.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash(git push*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/guicheng.tong/Desktop/claude-ws/.claude/hooks/pre-push-test.sh",
            "timeout": 300
          },
          {
            "type": "command",
            "command": "bash /Users/guicheng.tong/Desktop/claude-ws/.claude/hooks/pre-push-doc-review.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash /Users/guicheng.tong/Desktop/claude-ws/.claude/hooks/pre-push-version-check.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
